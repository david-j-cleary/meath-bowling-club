---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const events = [
  {
    title: 'Saturday Club Open Day',
    date: 'June 21, 2026',
    time: '10:00 AM',
    location: 'Meath Bowling Club green'
  },
  {
    title: 'Summer social evening',
    date: 'July 9, 2026',
    time: '7:00 PM',
    location: 'Clubhouse'
  }
];
---
<BaseLayout title="Events" description="Upcoming events and matches at Meath Bowling Club.">
  <SiteHeader currentUser={null} slot="header" />
  <section class="bg-club-50">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="space-y-6">
        <div class="space-y-3">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-club-700">Events</p>
          <h1 class="text-4xl font-semibold text-club-900 sm:text-5xl">Upcoming club activities</h1>
          <p class="max-w-3xl text-lg leading-8 text-club-500">Discover matches, social gatherings, and training sessions for members and guests.</p>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {events.map((event) => (
            <article class="rounded-3xl bg-white p-6 shadow-sm">
              <img src="/images/club-green.svg" alt="Event image" class="mb-4 h-40 w-full rounded-2xl object-cover" />
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-club-300">{event.date}</p>
              <h2 class="mt-4 text-2xl font-semibold text-club-900">{event.title}</h2>
              <p class="mt-3 text-club-500">{event.time} · {event.location}</p>
              <span class="mt-6 inline-flex items-center text-club-300 cursor-not-allowed" aria-disabled="true">View details</span>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
  <SiteFooter slot="footer" />
</BaseLayout>
