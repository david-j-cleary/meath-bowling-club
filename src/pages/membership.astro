---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<BaseLayout title="Membership" description="Membership details for Meath Bowling Club.">
  <SiteHeader currentUser={null} slot="header" />
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="space-y-8">
        <div class="space-y-4">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-club-700">Membership</p>
          <h1 class="text-4xl font-semibold text-club-900 sm:text-5xl">Join Meath Bowling Club</h1>
          <p class="max-w-3xl text-lg leading-8 text-club-500">Become part of a friendly sports community with events, coaching, and member-only updates.</p>
        </div>
          <div class="rounded-3xl overflow-hidden bg-white shadow-sm">
            <img src="/images/gallery-2.svg" alt="Membership placeholder" class="w-full object-cover" />
          </div>
        <div class="grid gap-6 lg:grid-cols-3">
          <article class="rounded-3xl bg-club-50 p-6 shadow-sm">
            <p class="text-sm uppercase tracking-[0.24em] text-club-300">Why join</p>
            <h2 class="mt-4 text-xl font-semibold text-club-900">Support the club</h2>
            <p class="mt-3 text-club-500">Members help keep the club strong and connected through events, coaching, and community spirit.</p>
          </article>
          <article class="rounded-3xl bg-club-50 p-6 shadow-sm">
            <p class="text-sm uppercase tracking-[0.24em] text-club-300">Member benefits</p>
            <h2 class="mt-4 text-xl font-semibold text-club-900">Get more from the club</h2>
            <p class="mt-3 text-club-500">Enjoy member-only notices, documents, and invitations to private club events.</p>
          </article>
          <article class="rounded-3xl bg-club-50 p-6 shadow-sm">
            <p class="text-sm uppercase tracking-[0.24em] text-club-300">How to join</p>
            <h2 class="mt-4 text-xl font-semibold text-club-900">Simple sign-up process</h2>
            <p class="mt-3 text-club-500">Contact us to start your membership journey and learn more about club activities.</p>
          </article>
        </div>
        <div class="rounded-3xl bg-club-50 p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-club-900">Membership process</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-3">
            <div class="rounded-3xl bg-white p-6 shadow-sm">
              <p class="text-sm uppercase tracking-[0.24em] text-club-300">Step 1</p>
              <p class="mt-3 text-lg font-semibold text-club-900">Contact us</p>
              <p class="mt-2 text-club-500">Ask about membership and upcoming welcome sessions.</p>
            </div>
            <div class="rounded-3xl bg-white p-6 shadow-sm">
              <p class="text-sm uppercase tracking-[0.24em] text-club-300">Step 2</p>
              <p class="mt-3 text-lg font-semibold text-club-900">Visit the club</p>
              <p class="mt-2 text-club-500">Meet members and see the green before joining.</p>
            </div>
            <div class="rounded-3xl bg-white p-6 shadow-sm">
              <p class="text-sm uppercase tracking-[0.24em] text-club-300">Step 3</p>
              <p class="mt-3 text-lg font-semibold text-club-900">Become a member</p>
              <p class="mt-2 text-club-500">Receive full access to member resources and events.</p>
            </div>
          </div>
        </div>
        <div class="rounded-3xl bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-club-900">Need help?</h2>
          <p class="mt-4 text-club-500">If you have questions about membership, email us or use the contact form on the website.</p>
          <a href="/contact" class="mt-6 inline-flex items-center rounded-full bg-club-700 px-6 py-3 text-base font-semibold text-white hover:bg-club-600 transition-colors">Contact the club</a>
        </div>
      </div>
    </div>
  </section>
  <SiteFooter slot="footer" />
</BaseLayout>
