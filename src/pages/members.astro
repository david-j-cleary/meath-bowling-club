---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import AuthGate from '../components/AuthGate.astro';

const widgets = [
  { title: 'Member notices', description: 'Access member-only announcements and club updates.', action: '/news' },
  { title: 'Event details', description: 'View upcoming members-only events and match information.', action: '/events' },
  { title: 'Documents', description: 'Download member resources and club paperwork.', action: '/contact' }
];
---
<BaseLayout title="Members" description="Members-only area for Meath Bowling Club.">
  <SiteHeader currentUser={null} slot="header" />
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <AuthGate requiredRole="member">
        <div class="space-y-8">
          <div class="space-y-3">
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-club-700">Members area</p>
            <h1 class="text-4xl font-semibold text-club-900 sm:text-5xl">Member resources and updates</h1>
            <p class="max-w-3xl text-lg leading-8 text-club-500">Welcome back. Here's your quick access to member-only notices, events, and documents.</p>
          </div>
          <div class="rounded-3xl overflow-hidden bg-club-50 p-0 shadow-sm">
            <img src="/images/club-green.svg" alt="Members area" class="w-full object-cover" />
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {widgets.map((widget) => (
              <article class="rounded-3xl bg-club-50 p-6 shadow-sm">
                <h2 class="text-xl font-semibold text-club-900">{widget.title}</h2>
                <p class="mt-3 text-club-500">{widget.description}</p>
                <a href={widget.action} class="mt-6 inline-flex items-center text-club-700 hover:underline">Open</a>
              </article>
            ))}
          </div>
        </div>
      </AuthGate>
    </div>
  </section>
  <SiteFooter slot="footer" />
</BaseLayout>
