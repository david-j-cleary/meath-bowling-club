---
import '../styles/global.css';
const { title, description, children } = Astro.props;
const pageTitle = title ? `${title} | Meath Bowling Club` : 'Meath Bowling Club';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description ?? 'Community lawn bowls club in Meath.'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-club-50 text-club-900 antialiased">
    <div class="min-h-screen flex flex-col">
      <slot name="header" />
      <main class="flex-1"><slot /></main>
      <slot name="footer" />
    </div>
  </body>
</html>
