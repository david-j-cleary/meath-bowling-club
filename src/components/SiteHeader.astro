---
import AuthNav from './AuthNav.astro';
---
<header class="bg-white border-b border-slate-200">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3 text-club-700">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-club-100 text-lg font-bold">M</span>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em]">Meath Bowling Club</p>
        <p class="text-xs text-slate-600">Lawn bowls for the local community</p>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-700">
      <a href="/about">About</a>
      <a href="/membership">Membership</a>
      <a href="/news">News</a>
      <a href="/events">Events</a>
      <a href="/gallery">Gallery</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="hidden md:block">
      <AuthNav />
    </div>
    <div class="md:hidden">
      <AuthNav />
    </div>
  </div>
</header>
